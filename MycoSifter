# --- Graph 5: PCoA Before vs After ---
png(file.path(output_dir, "05_pcoa_before_after.png"), width = 2800, height = 1400, res = 200)

ps_orig_rel <- transform_sample_counts(ps_filtered, function(x) x/sum(x))
ps_clean_rel <- transform_sample_counts(ps_final, function(x) x/sum(x))

dist_orig <- distance(ps_orig_rel, method = "bray")
dist_clean <- distance(ps_clean_rel, method = "bray")

pcoa_orig <- cmdscale(dist_orig, k = 2, eig = TRUE)
pcoa_clean <- cmdscale(dist_clean, k = 2, eig = TRUE)

var_orig <- round(100 * pcoa_orig$eig / sum(pcoa_orig$eig), 1)[1:2]
var_clean <- round(100 * pcoa_clean$eig / sum(pcoa_clean$eig), 1)[1:2]

meta_df <- as.data.frame(sample_data(ps_filtered))

par(mfrow = c(1, 2), mar = c(5, 5, 4, 2))

# Before
plot(pcoa_orig$points[,1], pcoa_orig$points[,2],
     pch = 21, bg = "#E41A1C40", col = "#E41A1C", cex = 1.5,
     xlab = paste0("PCoA1 (", var_orig[1], "%)"),
     ylab = paste0("PCoA2 (", var_orig[2], "%)"),
     main = paste0("BEFORE (", ntaxa(ps_filtered), " spp)"))

# After
plot(pcoa_clean$points[,1], pcoa_clean$points[,2],
     pch = 21, bg = "#377EB840", col = "#377EB8", cex = 1.5,
     xlab = paste0("PCoA1 (", var_clean[1], "%)"),
     ylab = paste0("PCoA2 (", var_clean[2], "%)"),
     main = paste0("AFTER (", ntaxa(ps_final), " spp)"))

dev.off()
cat("  ✔ 05_pcoa_before_after.png\n")

